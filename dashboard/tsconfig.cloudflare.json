{
  "compilerOptions": {
    "composite": true,
    "verbatimModuleSyntax": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true
  },
  "include": [
    "workers/app.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    ".react-router/types/**/*"
  ]
}
